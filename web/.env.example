# API 配置
VITE_API_BASE_URL=http://localhost:7080
VITE_WS_BASE_URL=ws://localhost:7080

# 视频生成配置
# 选择提供商: replicate 或 local
VITE_VIDEO_PROVIDER=replicate

# Replicate API 配置（用于云端 Wav2Lip）
# 从 https://replicate.com/account 获取 API Key
VITE_REPLICATE_API_KEY=r8_your_api_key_here

# 本地 Wav2Lip API 配置（可选，用于自建服务）
# VITE_LOCAL_VIDEO_API_URL=http://localhost:5000

# TTS 配置（可选）
# VITE_TTS_PROVIDER=openai
# VITE_OPENAI_API_KEY=sk-...
